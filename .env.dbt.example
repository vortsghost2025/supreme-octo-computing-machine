# DBT MCP Configuration
# Copy this file to .env (or .env.dbt) and fill in the values

DBT_PROJECT_DIR=/path/to/your/dbt/project
DBT_PATH=/path/to/dbt/executable
# Optional variables for remote/platform usage:
# DBT_HOST=https://cloud.getdbt.com
# DBT_TOKEN=your-dbt-token
# DBT_ACCOUNT_ID=your-account-id
# DBT_PROD_ENV_ID=your-prod-env-id
