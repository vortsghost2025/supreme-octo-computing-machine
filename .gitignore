# Local secrets and runtime configs
.env
.env.rotation

# Local env overrides
ui/.env.local
ui/.env.production

# Logs and build outputs
logs/
ui/dist/

# Browser data - NEVER track
chromium-cache/
chromium-profile/
kilo/
chrome-win/

# Node deps
node_modules/
ui/node_modules/

# Python cache/artifacts
__pycache__/
*.pyc

# Local preflight/temp artifacts
.preflight.json
.snac_*.txt/
.azure/
.aider*
.consolidation-backup/
ollama_profile/

# Block Azure deployment configs (may contain secrets)
main.bicep
infra/main.bicep

# ============================================================
# CRITICAL: Prevent duplicate nested projects
# Added after consolidation - April 7, 2026
# ============================================================

# Block nested duplicate directories
supreme-octo-computing-machine/
.supreme-octo-computing-machine/
*/supreme-octo-computing-machine/
**/supreme-octo-computing-machine/

# Block temporary agent directories
.agent-temp/
.agent-work/

# Block duplicate project markers
.DUPLICATE-DETECTED

# Keep consolidation backups for 30 days (manually delete later)
# .consolidation-backup/

# Block ollama profile data (may contain secrets)
ollama_profile/

# Block binary artifacts
*.sqlite
*.nsys-rep
