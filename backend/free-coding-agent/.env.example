# Free Coding Agent — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── LLM Provider ─────────────────────────────────────────────
# Which provider Ollama/Groq/Together to use
PROVIDER=ollama
MODEL=llama3.2
OLLAMA_URL=http://host.docker.internal:11434

# ── MCP: GitHub integration ───────────────────────────────────
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org
# ⚠️  ROTATE IMMEDIATELY if this token was ever committed to a repo or shared.
GITHUB_TOKEN=ghp_your-github-token-here

# ── MCP: Brave Search ────────────────────────────────────────
# Get at: https://brave.com/search/api/
# ⚠️  ROTATE IMMEDIATELY if this key was ever committed to a repo or shared.
BRAVE_API_KEY=your-brave-api-key-here

# ── Database (optional) ──────────────────────────────────────
# PostgreSQL connection string for postgres MCP tools
DATABASE_URL=postgresql://snac:yourpassword@db:5432/snac

# ── Server ───────────────────────────────────────────────────
PORT=3001

# ── Agent behaviour ──────────────────────────────────────────
# Set to true to run without human approval prompts
NO_APPROVAL=false
WORKING_DIR=/workspace
