# SNAC-v2 Environment Variables
# Copy this file to .env and fill in the values

# OpenAI API Key (required for LLM features)
OPENAI_API_KEY=sk-your-openai-key-here

# Database
POSTGRES_PASSWORD=agent_secure_password_$(openssl rand -hex 8)

# Service URLs (usually don't need to change)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
REDIS_HOST=redis
REDIS_PORT=6379

# Web IDE password (required for snac-ide service)
IDE_PASSWORD=changeme

# Optional: Adjust these for your deployment
# BACKEND_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000

# GitHub Token (optional, for GitHub API operations)
# GITHUB_TOKEN=ghp_your_token_here