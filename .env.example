# SNAC-v2 Environment Variables
# Copy this file to .env and fill in the values

# ── AI providers ─────────────────────────────────────────────────────────────

# OpenAI API Key (required for LLM/embedding features in the backend)
# ⚠️  This is PAY-PER-USE — NOT covered by your Claude.ai $30/mo subscription.
# Set a hard spending limit at https://console.anthropic.com to avoid surprises.
OPENAI_API_KEY=sk-your-openai-key-here

# Database
# Use a strong random password — do NOT use the placeholder value in production.
# Generate one: openssl rand -hex 16
POSTGRES_PASSWORD=agent_secure_password_changeme

# ── Service URLs (usually don't need to change) ───────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
REDIS_HOST=redis
REDIS_PORT=6379

# ── Free Coding Agent (snac_free_agent) ───────────────────────────────────────
# GitHub personal access token — create at https://github.com/settings/tokens
# Required scopes: repo, read:org
# Replace the ENTIRE value below (including the ghp_ prefix) with your real token.
# ⚠️  REVOKE IMMEDIATELY if this key was ever committed to a repo or shared in a chat log.
GITHUB_TOKEN=ghp_replace_this_entire_value_with_your_real_token

# Brave Search API key — get at https://brave.com/search/api/
# ⚠️  REVOKE IMMEDIATELY if this value was ever committed to a repo or chat log.
BRAVE_API_KEY=your-brave-api-key-here

# ── Memory governor (prevents runaway write storms) ───────────────────────────
# Maximum memory writes per minute across all agents
MAX_WRITES_PER_MINUTE=200
# Maximum vector embeddings inserted per minute
MAX_VECTOR_INSERTS=50
# Maximum in-memory store size in MB before writes are paused
MAX_MEMORY_SIZE_MB=500

# ── Safe mode — enable after a crash, scale up slowly ────────────────────────
# When true: disables memory sync, vector embedding, and swarm spawn.
# Only 1 agent, 1 memory store, 1 task at a time.  Set to false once stable.
SNAC_SAFE_MODE=false

# ── Optional overrides ────────────────────────────────────────────────────────
# BACKEND_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000